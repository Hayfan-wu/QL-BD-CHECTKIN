{
  "manifest_version": 3,
  "name": "BDUSS 提取工具",
  "version": "1.0.0",
  "description": "一键提取百度网盘 BDUSS Cookie，用于青龙面板签到配置",
  "permissions": [
    "cookies"
  ],
  "host_permissions": [
    "*://*.baidu.com/*",
    "*://*.pan.baidu.com/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "BDUSS 提取工具",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
